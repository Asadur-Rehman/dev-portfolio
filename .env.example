# =============================================================================
# Asad ur Rehman — Portfolio environment variables
# Copy this file to `.env.local` and fill in real values.
# Variables prefixed NEXT_PUBLIC_ are exposed to the browser.
# =============================================================================

# -----------------------------------------------------------------------------
# Site URL (used by sitemap.xml, robots.txt, JSON-LD, Open Graph)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://asadurrehman.dev

# -----------------------------------------------------------------------------
# Contact form — Web3Forms (default, simplest, free, no account email setup)
#   1. Visit https://web3forms.com
#   2. Enter your email, get an access key
#   3. Paste it below
# Free tier: unlimited submissions
# -----------------------------------------------------------------------------
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=your_web3forms_access_key

# -----------------------------------------------------------------------------
# (Optional) EmailJS — alternative to Web3Forms if you prefer
#   1. Sign up at https://emailjs.com (free)
#   2. Add an email service (Gmail / Outlook)
#   3. Create a template with vars: {{from_name}}, {{from_email}}, {{message}}
# Free tier: 200 emails / month
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxx
# NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxx
# NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_emailjs_public_key

# -----------------------------------------------------------------------------
# (Optional) Resend — server-side email if you wire up a /api route later
#   1. Sign up at https://resend.com (free)
#   2. Verify a domain (or use their test domain)
#   3. Generate an API key
# Free tier: 100/day, 3000/month
# -----------------------------------------------------------------------------
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# (Optional) Google Analytics
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
